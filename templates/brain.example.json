  "tech_stack": {
    "frontend": {
      "framework": "Next.js 14",
      "language": "TypeScript",
      "ui_library": "shadcn/ui",
      "state_management": "Zustand",
      "styling": "TailwindCSS"
    },
    "backend": {
      "framework": "Next.js API Routes",
      "language": "TypeScript",
      "runtime": "Node.js 20"
    },
    "database": {
      "type": "PostgreSQL",
      "orm": "Prisma",
      "name": "coffee_shop_db"
