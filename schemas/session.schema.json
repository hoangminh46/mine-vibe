{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mine.dev/schemas/session.schema.json",
  "title": "Mine Session State Schema",
  "description": "Dynamic session snapshot - current branch, working tree, and next actions",
  "version": "2.0.0",
  "type": "object",
  "required": ["updated_at"],
  "properties": {
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "working_on": {
      "type": "object",
      "description": "Current work in progress",
      "properties": {
        "feature": { "type": "string", "description": "Feature name" },
        "task": { "type": "string", "description": "Current task" },
        "status": {
          "type": "string",
          "enum": ["planning", "coding", "testing", "debugging", "reviewing"],
          "description": "Task status"
        },
        "current_plan_path": {
          "type": "string",
          "description": "Path to current plan folder (e.g., plans/260117-1430-orders/)"
        },
        "current_phase": {
          "type": "string",
          "description": "Current phase being worked on (e.g., phase-03)"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files being modified"
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Current blockers"
        },
        "notes": { "type": "string", "description": "Quick notes" }
      }
    },
    "current_branch": {
      "type": "string",
      "description": "Git branch currently checked out"
    },
    "last_recap_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last time /recap was run"
    },
    "active_handoff_id": {
      "type": "string",
      "description": "Most recent handoff entry ID from history.json"
    },
    "git_snapshot": {
      "type": "object",
      "description": "Verified git state at the moment of save",
      "properties": {
        "head_sha": { "type": "string" },
        "head_summary": { "type": "string" },
        "head_authored_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_saved_head_sha": {
          "type": "string",
          "description": "HEAD sha captured during the previous successful /save-brain"
        },
        "base_sha": {
          "type": "string",
          "description": "Commit used as the comparison base for this save"
        },
        "branch": { "type": "string" },
        "has_uncommitted_changes": { "type": "boolean" },
        "changed_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "staged_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unstaged_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "untracked_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commit_range": {
          "type": "string",
          "description": "Range reviewed since previous save, for example abc123..def456"
        },
        "commits_since_last_save": {
          "type": "array",
          "description": "Commits included in the current handoff",
          "items": {
            "type": "object",
            "properties": {
              "sha": { "type": "string" },
              "author": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "message": { "type": "string" }
            },
            "required": ["sha", "message"]
          }
        }
      }
    },
    "pending_tasks": {
      "type": "array",
      "description": "Tasks to do next",
      "items": {
        "type": "object",
        "properties": {
          "task": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "notes": { "type": "string" }
        },
        "required": ["task", "priority"]
      }
    },
    "recent_changes": {
      "type": "array",
      "description": "Verified recent changes, preferably derived from commit history or current working tree",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "type": { "type": "string", "enum": ["feature", "bugfix", "refactor", "config", "docs"] },
          "source": {
            "type": "string",
            "enum": ["commit", "working_tree"],
            "description": "Whether the change came from committed history or local uncommitted work"
          },
          "commit_sha": { "type": "string" },
          "description": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors_encountered": {
      "type": "array",
      "description": "Errors encountered and solutions",
      "items": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "solution": { "type": "string" },
          "resolved": { "type": "boolean" }
        }
      }
    },
    "decisions_made": {
      "type": "array",
      "description": "Technical decisions made this session",
      "items": {
        "type": "object",
        "properties": {
          "decision": { "type": "string" },
          "reason": { "type": "string" },
          "commit_sha": { "type": "string" }
        }
      }
    },
    "skipped_tests": {
      "type": "array",
      "description": "Tests that were skipped due to fix failures - blocks deploy!",
      "items": {
        "type": "object",
        "properties": {
          "test": { "type": "string", "description": "Test file name" },
          "reason": { "type": "string", "description": "Why it was skipped" },
          "date": { "type": "string", "format": "date-time" }
        },
        "required": ["test", "date"]
      }
    },
    "uncommitted_summary": {
      "type": "object",
      "description": "Short summary of local work not yet committed",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["clean", "dirty"]
        },
        "summary": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
